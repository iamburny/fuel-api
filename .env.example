# ── App ──────────────────────────────────────
PORT=8000
NODE_ENV=development

# ── Database ─────────────────────────────────
# Dev (SQLite):
DATABASE_URL="file:./fuel.db"
# Prod (PostgreSQL):
# DATABASE_URL="postgresql://fuel:secret@localhost:5432/fueldb"

# ── Gov Fuel Finder API ─────────────────────
# Register at https://www.developer.fuel-finder.service.gov.uk/
FUEL_FINDER_CLIENT_ID=your-client-id
FUEL_FINDER_CLIENT_SECRET=your-client-secret

# ── Polling (Fair Use Policy: avg ≤ 5 min for public-facing) ──
POLL_INTERVAL_MINUTES=5

# ── JWT Auth ─────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=24h

# ── Google Sign-In ───────────────────────────
# The Web OAuth client ID (from Google Cloud Console). Used as the audience when verifying
# ID tokens from the Android app and web frontend. Leave empty to disable Google login.
GOOGLE_CLIENT_ID=

# ── Admin endpoints (ingest trigger, compliance stats/log, discrepancy list) ──
# Generate with: openssl rand -hex 32
ADMIN_API_KEY=change-this-to-a-long-random-string

# ── CORS (comma-separated allowed origins) ──
# Add the admin console origin (fuel-admin) so it can call the API from the browser.
CORS_ALLOWED_ORIGINS=https://fueltracker.uk,https://www.fueltracker.uk,https://admin.fueltracker.uk,http://localhost:3000,http://localhost:3001

# ── Firebase Cloud Messaging (price-drop push notifications) ──
# Inline service-account JSON, or a path to the JSON file. Leave empty to disable
# push (send calls become no-ops). From the Firebase console → Project settings →
# Service accounts → Generate new private key.
FIREBASE_SERVICE_ACCOUNT=

# ── Compliance ───────────────────────────────
DISCREPANCY_REPORT_URL=https://www.fuel-finder.service.gov.uk/report-discrepancy
