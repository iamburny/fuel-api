# Postgres password (shared between db and api containers via docker-compose)
POSTGRES_PASSWORD=change-this-to-a-strong-password

# Gov Fuel Finder API credentials
FUEL_FINDER_CLIENT_ID=your-client-id
FUEL_FINDER_CLIENT_SECRET=your-client-secret

# Polling interval (minutes) — minimum 5 per Fair Use Policy
POLL_INTERVAL_MINUTES=30

# JWT auth for app users
JWT_SECRET=generate-a-long-random-string-here

# These are set in docker-compose.yml, no need to duplicate:
# PORT=8000
# DATABASE_URL=postgresql://fuel:PASSWORD@fuel-db:5432/fueldb
# NODE_ENV=production
